# ─────────────────────────────────────────────────────────────────
# J.A.R.V.I.S. Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Anthropic API Key (required) ─────────────────────────────────
# Get yours at: https://console.anthropic.com/
# Starts with: sk-ant-
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── GitHub Personal Access Token (required for website generator) ─
# Get yours at: https://github.com/settings/tokens?type=beta
# Required scopes: Contents (read/write), Metadata (read), Administration (read/write)
# Starts with: github_pat_ or ghp_
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ── Dashboard Auth Token (optional) ──────────────────────────────
# If set, the dashboard requires this token to log in.
# Leave commented out for open access on a trusted local machine.
# JARVIS_AUTH_TOKEN=your-secret-token-here
